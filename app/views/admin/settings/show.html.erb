<% content_for :title, "Settings" %>
<div class="max-w-4xl mx-auto py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Settings</h1>
    <p class="mt-2 text-sm text-gray-500">Manage global application settings.</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Payment Methods</h2>
      <div class="border-t border-gray-100 pt-4">
        <%= form_with url: admin_settings_path, method: :patch, class: "space-y-6" do |f| %>
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">M-PESA Payment Mode</label>
            <p class="text-sm text-gray-500 mb-4">Choose how you want to handle M-PESA payments during checkout.</p>

            <div class="space-y-4">
              <label class="flex items-start gap-3 cursor-pointer p-4 border rounded-lg <%= 'border-green-500 bg-green-50' if @mpesa_mode == 'automated' %> hover:bg-gray-50 transition" onclick="document.querySelectorAll('label').forEach(l => l.classList.remove('border-green-500', 'bg-green-50')); this.classList.add('border-green-500', 'bg-green-50')">
                <div class="flex items-center h-5">
                  <%= f.radio_button :mpesa_mode, 'automated', checked: @mpesa_mode == 'automated', class: "w-4 h-4 text-green-600 focus:ring-green-500 border-gray-300" %>
                </div>
                <div>
                  <div class="font-bold text-gray-900">Automated (STK Push)</div>
                  <div class="text-sm text-gray-500 mt-1">Prompt users on their phone directly for payment using M-PESA API.</div>
                </div>
              </label>

              <label class="flex items-start gap-3 cursor-pointer p-4 border rounded-lg <%= 'border-green-500 bg-green-50' if @mpesa_mode == 'manual' %> hover:bg-gray-50 transition" onclick="document.querySelectorAll('label').forEach(l => l.classList.remove('border-green-500', 'bg-green-50')); this.classList.add('border-green-500', 'bg-green-50')">
                <div class="flex items-center h-5">
                  <%= f.radio_button :mpesa_mode, 'manual', checked: @mpesa_mode == 'manual', class: "w-4 h-4 text-green-600 focus:ring-green-500 border-gray-300" %>
                </div>
                <div>
                  <div class="font-bold text-gray-900">Manual (Reference Code)</div>
                  <div class="text-sm text-gray-500 mt-1">Display Paybill instructions and require users to input their transaction reference manually.</div>
                </div>
              </label>
            </div>
          </div>

          <div class="flex justify-end pt-4 border-t border-gray-100">
            <%= f.submit "Save Settings", class: "bg-gray-900 text-white px-6 py-2 rounded-lg font-medium hover:bg-black transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
