<% content_for :title, "Settings" %>
<div class="max-w-4xl mx-auto py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Settings</h1>
    <p class="mt-2 text-sm text-gray-500">Manage global application settings.</p>
  </div>

  <div x-data="{ activeTab: 'payment' }" class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <!-- Tabs Navigation -->
    <div class="border-b border-gray-200">
      <nav class="flex -mb-px" aria-label="Tabs">
        <button 
          @click="activeTab = 'payment'"
          :class="{ 'border-red-500 text-red-600': activeTab === 'payment', 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300': activeTab !== 'payment' }"
          class="w-1/2 py-4 px-1 text-center border-b-2 font-medium text-sm transition-colors cursor-pointer"
        >
          <i class="fa-solid fa-credit-card mr-2"></i> Payment Methods
        </button>
        <button 
          @click="activeTab = 'users'"
          :class="{ 'border-red-500 text-red-600': activeTab === 'users', 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300': activeTab !== 'users' }"
          class="w-1/2 py-4 px-1 text-center border-b-2 font-medium text-sm transition-colors cursor-pointer"
        >
          <i class="fa-solid fa-users mr-2"></i> User Management
        </button>
      </nav>
    </div>

    <!-- Payment Methods Tab -->
    <div x-show="activeTab === 'payment'" class="p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Payment Methods</h2>
      <div class="pt-2">
        <%= form_with url: admin_settings_path, method: :patch, class: "space-y-6" do |f| %>
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">M-PESA Payment Mode</label>
            <p class="text-sm text-gray-500 mb-4">Choose how you want to handle M-PESA payments during checkout.</p>

            <div class="space-y-4">
              <label class="flex items-start gap-3 cursor-pointer p-4 border rounded-lg <%= 'border-green-500 bg-green-50' if @mpesa_mode == 'automated' %> hover:bg-gray-50 transition" onclick="document.querySelectorAll('label').forEach(l => l.classList.remove('border-green-500', 'bg-green-50')); this.classList.add('border-green-500', 'bg-green-50')">
                <div class="flex items-center h-5">
                  <%= f.radio_button :mpesa_mode, 'automated', checked: @mpesa_mode == 'automated', class: "w-4 h-4 text-green-600 focus:ring-green-500 border-gray-300" %>
                </div>
                <div>
                  <div class="font-bold text-gray-900">Automated (STK Push)</div>
                  <div class="text-sm text-gray-500 mt-1">Prompt users on their phone directly for payment using M-PESA API.</div>
                </div>
              </label>

              <label class="flex items-start gap-3 cursor-pointer p-4 border rounded-lg <%= 'border-green-500 bg-green-50' if @mpesa_mode == 'manual' %> hover:bg-gray-50 transition" onclick="document.querySelectorAll('label').forEach(l => l.classList.remove('border-green-500', 'bg-green-50')); this.classList.add('border-green-500', 'bg-green-50')">
                <div class="flex items-center h-5">
                  <%= f.radio_button :mpesa_mode, 'manual', checked: @mpesa_mode == 'manual', class: "w-4 h-4 text-green-600 focus:ring-green-500 border-gray-300" %>
                </div>
                <div>
                  <div class="font-bold text-gray-900">Manual (Reference Code)</div>
                  <div class="text-sm text-gray-500 mt-1">Display Paybill instructions and require users to input their transaction reference manually.</div>
                </div>
              </label>
            </div>
          </div>

          <div class="mt-8">
            <label class="block text-sm font-bold text-gray-700 mb-2">M-PESA Business Number (Paybill/Till)</label>
            <p class="text-sm text-gray-500 mb-4">This number is displayed to users when they choose Manual (Reference Code) payment.</p>
            <%= f.text_field :mpesa_business_number, value: @mpesa_business_number, class: "w-full max-w-md border border-gray-300 rounded-lg px-4 py-2 focus:ring-green-500 focus:border-green-500 transition shadow-sm", placeholder: "e.g. 123456" %>
          </div>

          <div class="flex justify-end pt-8 border-t border-gray-100 mt-8">
            <%= f.submit "Save Settings", class: "bg-gray-900 text-white px-6 py-2 rounded-lg font-medium hover:bg-black transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- User Management Tab -->
    <div x-show="activeTab === 'users'" x-cloak class="p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">User Management</h2>
      <p class="text-sm text-gray-500 mb-6">Invite new administrators and manage existing users. When you add a new user, they will receive an email to set their own password.</p>

      <!-- Add New User Form -->
      <div class="bg-gray-50 p-6 rounded-xl border border-gray-200 mb-8">
        <h3 class="text-md font-bold text-gray-900 mb-4">Add New User</h3>
        <%= form_with url: admin_users_path, method: :post, class: "flex items-end gap-4 flex-wrap" do |f| %>
          <div class="grow min-w-[200px]">
             <%= render InputComponent.new(
              label: "First Name",
              name: "first_name",
              id: "first_name",
              type: "text",
              required: true,
              placeholder: "e.g. Jane"
            ) %>
          </div>
          <div class="grow min-w-[200px]">
             <%= render InputComponent.new(
              label: "Last Name",
              name: "last_name",
              id: "last_name",
              type: "text",
              required: true,
              placeholder: "e.g. Doe"
            ) %>
          </div>
          <div class="grow min-w-[250px]">
             <%= render InputComponent.new(
              label: "Email Address",
              name: "email_address",
              id: "email_address",
              type: "email",
              required: true,
              placeholder: "e.g. jane@example.com"
            ) %>
          </div>
          <div class="mb-1">
            <%= render ButtonComponent.new(intent: :danger, type: "submit", class: "whitespace-nowrap h-[42px]") do %>
              Invite User
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Users List -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50 text-gray-500 text-sm uppercase tracking-wider">
              <th class="px-4 py-3 font-medium">Name</th>
              <th class="px-4 py-3 font-medium">Email</th>
              <th class="px-4 py-3 font-medium">Joined</th>
              <th class="px-4 py-3 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @users.each do |user| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold text-xs uppercase">
                      <%= user.first_name[0] %><%= user.last_name[0] %>
                    </div>
                    <span class="font-medium text-gray-900"><%= user.full_name %></span>
                    <% if user == Current.user %>
                      <span class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-bold ml-2">YOU</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= user.email_address %></td>
                <td class="px-4 py-3 text-gray-500 text-sm"><%= time_ago_in_words(user.created_at) %> ago</td>
                <td class="px-4 py-3 text-right">
                  <% if user != Current.user %>
                    <%= button_to admin_user_path(user), method: :delete, class: "text-red-500 hover:text-red-700 transition font-medium text-sm border-none bg-transparent cursor-pointer", form: { data: { turbo_confirm: 'Are you sure you want to remove this user?' } } do %>
                      <i class="fa-solid fa-trash-can mr-1"></i> Remove
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
</div>
