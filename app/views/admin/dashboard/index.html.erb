<% content_for :title, "Dashboard" %>
<h1 class="font-bold text-2xl">Dashboard</h1>
<h2 class="text-l">Welcome  <%= Current.user.first_name %> <%= Current.user.last_name %></h2>
<hr class="my-4 border-gray-200"/>
<div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-8 mt-2">
  <%# Events tile with events count and calendar icon %>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500 ">Events</h2>
      <i class="fa-solid fa-calendar text-gray-500"></i>
    </div>
    <p class="text-lg font-medium  my-6"><%= @events %></p>
  <% end %>
  <%# Tickets sold tile with tickets count and ticket icon%>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500 ">Tickets Sold</h2>
      <i class="fa-solid fa-ticket text-gray-500"></i>
    </div>
    <p class="text-lg font-medium  my-6"><%= @tickets_sold %></p>
  <% end %>
  <%# Revenue tile with revenue count and dollar icon%>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500 ">Revenue</h2>
      <i class="fa-solid fa-dollar text-gray-500"></i>
    </div>
    <p class="text-lg font-medium  my-6"><%= @revenue %></p>
  <% end %>
</div>
