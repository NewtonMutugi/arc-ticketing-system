<div class="fixed top-5 right-5 z-50 flex flex-col gap-4 w-96 pointer-events-none">
  <% flash.each do |key, message| %>
    <%
      # Map standard Rails flash keys to your Component types
      type = case key.to_s
             when "notice" then :success
             when "alert" then :error
             else :info
             end

      # Title handling: Capitalize the type or use a custom title

      title = type.to_s.humanize
    %>
    <%= render ToastComponent.new(type: type, title: title, body: message) %>
  <% end %>
</div>
<div class="flex justify-center mt-8">
  <%= render CardComponent.new(class: "max-w-xl w-full p-8") do %>
    <div class="flex justify-center mb-4">
      <%= image_tag("/arc_logo.png", alt: "Africa Ruby Community Logo", class: "h-14 w-auto") %>
    </div>
    <%= form_with url: admin_session_path do |form| %>
      <%= render InputComponent.new(
        label: "Email Address",
        name: "email_address",
        id: "email_address",
        type: "email",
        value: params[:email_address],
        placeholder: " "
      ) %>
      <%= render InputComponent.new(
        label: "Password",
        name: "password",
        id: "password",
        type: "password",
        placeholder: " "
      ) %>
      <div class="py-4">
        <%= render ButtonComponent.new(intent: :primary, type: "submit", class: "") do %>
          Sign in
        <% end %>
      </div>
    <% end %>
    <%= link_to "Forgot password?", new_admin_password_path , class: "hover:text-blue-500 hover:underline" %>
  <% end %>
</div>
