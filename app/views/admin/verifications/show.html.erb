<div class="min-h-screen flex items-center justify-center bg-gray-100 p-4">
  <div class="bg-white p-8 rounded-lg shadow-xl text-center max-w-sm w-full">
    <% if @status == :success %>
      <div class="rounded-full bg-green-100 p-4 w-20 h-20 mx-auto flex items-center justify-center mb-4">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <h1 class="text-2xl font-bold text-green-800 mb-2">Verified!</h1>
      <p class="text-gray-600 mb-6">Welcome, <%= @attendee.first_name %>.</p>
    <% else %>
      <div class="rounded-full bg-yellow-100 p-4 w-20 h-20 mx-auto flex items-center justify-center mb-4">
        <svg class="w-10 h-10 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
      </div>
      <h1 class="text-2xl font-bold text-yellow-800 mb-2">Duplicate Scan</h1>
      <p class="text-gray-600 mb-6">Checked in at <%= @attendee.checked_in_at.strftime("%I:%M %p") %></p>
    <% end %>
    <div class="border-t border-gray-200 pt-4 text-left">
      <div class="flex justify-between mb-2">
        <span class="text-gray-500 text-sm">Ticket Type:</span>
        <span class="font-semibold text-sm"><%= @attendee.ticket.title %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-500 text-sm">Order:</span>
        <span class="font-semibold text-sm"><%= @attendee.order.order_no %></span>
      </div>
    </div>
    <%= link_to "Back to Dashboard", admin_event_path(@event), class: "mt-8 block w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700" %>
  </div>
</div>
