<%= form_with(model: [:admin, @event, ticket], local: true, multipart: true, class: "w-full") do |f| %>
  <div class="modal-content bg-white rounded-lg shadow-xl overflow-hidden">
    <div class="modal-header flex justify-between items-center p-4 border-b border-gray-100">
      <h4 class="text-lg font-bold text-gray-800">
        <i class="fa fa-ticket text-red-600 mr-2"></i>
        <%= ticket.new_record? ? "Create New Ticket" : "Edit Ticket" %>
      </h4>
      <%= link_to admin_event_tickets_path(@event), class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <i class="fa-solid fa-times text-xl"></i>
      <% end %>
    </div>
    <div class="modal-body p-6 max-h-[80vh] overflow-y-auto">
      <% if ticket.errors.any? %>
        <div class="mb-4 p-4 bg-red-50 text-red-700 rounded border border-red-200 text-sm">
          <ul class="list-disc ml-5">
            <% ticket.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <div class="col-span-1 md:col-span-2">
          <%= render InputComponent.new(
            label: "Ticket Title",
            name: "ticket[title]",
            value: ticket.title,
            placeholder: "e.g. Early Bird Pass",
            required: true
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Ticket Price (0 for FREE)",
            name: "ticket[price]",
            type: "number",
            value: ticket.price,
            placeholder: "e.g. 5500",
            required: true
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Ticket Quantity",
            name: "ticket[quantity]",
            type: "number",
            value: ticket.quantity,
            placeholder: "e.g. 1000",
            required: true
          ) %>
        </div>
        <div class="col-span-1 md:col-span-2">
          <%= render InputComponent.new(
            label: "Description",
            name: "ticket[description]",
            type: "textarea",
            value: ticket.description,
            placeholder: "What does this ticket include? (e.g. Workshop access, Swag...)",
            required: true
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Start Sale Date",
            name: "ticket[start_sale_date]",
            type: "datetime",
            value: ticket.start_sale_date&.strftime("%Y-%m-%dT%H:%M")
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "End Sale Date",
            name: "ticket[end_sale_date]",
            type: "datetime",
            value: ticket.end_sale_date&.strftime("%Y-%m-%dT%H:%M")
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Minimum Ticket Per Order",
            name: "ticket[min_ticket]",
            type: "select",
            value: ticket.min_ticket || 1,
            options: (1..20).map { |n| [n.to_s, n] }
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Maximum Ticket Per Order",
            name: "ticket[max_ticket]",
            type: "select",
            value: ticket.max_ticket || 10,
            options: (1..20).map { |n| [n.to_s, n] }
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Make Ticket Visible",
            name: "ticket[status]",
            type: "select",
            value: ticket.status,
            options: [['Make Ticket Visible', true], ['Hide Ticket', false]]
          ) %>
        </div>
        <div>
          <%= render InputComponent.new(
            label: "Group Ticket Count",
            name: "ticket[group_ticket_count]",
            type: "select",
            value: ticket.group_ticket_count || 1,
            options: (1..20).map { |n| [n.to_s, n] }
          ) %>
          <p class="text-xs text-gray-500 mt-1">Defaults to 1 for non-group tickets</p>
        </div>
        <div class="col-span-1 md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-gray-100 pt-6 mt-2">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1"> Replace Ticket Image (optional) </label>
            <%= render FileUploadComponent.new(form: f, field: :ticket_image) %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1"> Current Ticket Image </label>
            <% if ticket.ticket_image.attached? %>
              <div class="relative w-full h-32 rounded border border-gray-200 overflow-hidden">
                <%= image_tag ticket.ticket_image.variant(:thumb, resize_to_fill: [300, 150]), class: "w-full h-full object-cover" %>
              </div>
            <% else %>
              <div class="w-full h-32 bg-gray-50 border border-dashed border-gray-300 rounded flex items-center justify-center text-gray-400 text-sm">
                No image set
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer p-4 border-t border-gray-100 bg-gray-50 flex justify-end gap-3">
      <%= link_to "Cancel", admin_event_tickets_path(@event), class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded shadow-sm hover:bg-gray-50", data: { turbo_frame: "_top" } %>
      <%= f.submit ticket.new_record? ? "Create Ticket" : "Update Ticket", class: "px-4 py-2 text-sm font-medium text-white bg-green-600 rounded shadow-sm hover:bg-green-700 cursor-pointer" %>
    </div>
  </div>
<% end %>
