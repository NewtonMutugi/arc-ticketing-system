<h1 class="font-bold text-2xl"><%= @event.title %></h1>
<h2 class="text-l">Welcome  <%= Current.user.first_name %> <%= Current.user.last_name %></h2>
<hr class="my-4 border-gray-200"/>
<div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-8 mt-2">
  <%# Orders tile with events count and calendar icon %>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500 ">Orders</h2>
      <i class="fa-solid fa-bag-shopping text-gray-500 text-2xl"></i>
    </div>
    <p class="text-lg font-medium  my-6"><%= @orders %></p>
  <% end %>
  <%# Tickets sold tile with tickets count and ticket icon%>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500">Tickets Sold</h2>
      <i class="fa-solid fa-ticket text-gray-500 text-2xl"></i>
    </div>
    <p class="text-lg font-medium  my-6"><%= @tickets_sold %></p>
  <% end %>
  <%# Revenue tile with revenue count and dollar icon%>
  <%= render CardComponent.new(class: "bg-white p-4") do %>
    <div class="flex items-center justify-between">
      <h2 class="text-lg font-medium text-gray-500 ">Revenue</h2>
      <i class="fa-solid fa-dollar text-gray-500 text-2xl"></i>
    </div>
    <%# TODO: Implement a way to calculate revenue %>
    <p class="text-lg font-medium  my-6"><%= @revenue ? @revenue : '0'%></p>
  <% end %>
</div>
<%# Display full event details and render image %>
<%= render CardComponent.new(class: "bg-white overflow-hidden shadow-sm rounded-lg mt-4") do %>
  <div class="flex flex-col md:flex-row min-h-[300px]">
    <div class="md:w-5/12 relative min-h-[200px] md:min-h-0 bg-gray-100">
      <% if @event.event_image.attached? %>
        <%= image_tag @event.event_image, class: "absolute inset-0 w-full h-full object-cover" %>
      <% else %>
        <div class="absolute inset-0 flex items-center justify-center text-gray-400">
          <i class="fa-regular fa-image text-4xl"></i>
        </div>
      <% end %>
    </div>
    <div class="md:w-7/12 p-6 flex flex-col">
      <div class="flex justify-between items-start mb-4">
        <div class="text-gray-600 leading-tight">
          <span class="text-3xl font-bold text-gray-900 block">
            <%= @event.start_date.strftime("%d") %>
          </span>
          <span class="text-sm font-bold uppercase text-red-600">
            <%= @event.start_date.strftime("%b") %>
          </span>
        </div>
        <%= link_to "Tickets", admin_event_tickets_path(@event), class: "rounded bg-red-600 px-4 py-2 text-xs font-bold text-white uppercase hover:bg-red-700 transition" %>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        <%= @event.title %>
      </h2>
      <div class="prose prose-sm text-gray-600 mb-6 line-clamp-4 grow">
        <%= @event.description %>
      </div>
      <div>
        <%= render ButtonComponent.new(intent: :secondary, href: event_path(@event)) do %>
          <i class="fa-solid fa-eye mr-2"></i>
          View Public Page
        <% end %>
      </div>
      <div class="mt-auto pt-4 border-t border-gray-100 text-sm text-gray-500 flex items-center gap-2">
        <i class="fa-solid fa-location-dot text-red-500"></i>
        <%= @event.location %>
      </div>
    </div>
  </div>
<% end %>
