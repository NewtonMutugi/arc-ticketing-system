<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
  <div class="flex justify-between items-center border-b border-gray-100 pb-4 mb-6">
    <h2 class="text-xl font-bold text-gray-800">Edit Event Details</h2>
    <%= link_to admin_event_path(@event), class: "text-gray-500 hover:text-gray-700 text-sm font-medium" do %>
      <i class="fa fa-arrow-left mr-1"></i> Back to Event
    <% end %>
  </div>
  <%= render "form", event: @event %>
</div>
