<%= form_with(model: event, local: true, multipart: true, class: "form-horizontal") do |f| %>
  <%# Error Handling Block %>
  <% if event.errors.any? %>
    <div class="alert alert-danger p-4 mb-4 bg-red-50 text-red-700 border border-red-200 rounded">
      <h4 class="font-bold"><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h4>
      <ul class="list-disc ml-5 mt-2">
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="row">
    <div class="form-group col-md-6 mb-4">
      <%= render InputComponent.new(
        label: "Event Name",
        name: "event[title]",
        id: "event_title",
        value: event.title,
        placeholder: "e.g. ARC Conference 2026"
      ) %>
    </div>
    <div class="form-group col-md-6 mb-4">
      <%= render InputComponent.new(
        label: "Make Event Public",
        name: "event[publish]",
        type: "select",
        value: event.publish,
        options: [['Make Event Page Public', true], ['Hide Event Page', false]]
      ) %>
    </div>
    <div class="form-group col-md-12 mb-4">
      <%= render InputComponent.new(
        label: "Event Description",
        name: "event[description]",
        type: "textarea",
        value: event.description,
        placeholder: "Describe the event details..."
      ) %>
    </div>
    <div class="form-group col-md-6 mb-4">
      <%= render InputComponent.new(
        label: "Start Date",
        name: "event[start_date]",
        type: "datetime",
        value: event.start_date&.strftime("%Y-%m-%dT%H:%M")
      ) %>
    </div>
    <div class="form-group col-md-6 mb-4">
      <%= render InputComponent.new(
        label: "End Date",
        name: "event[end_date]",
        type: "datetime",
        value: event.end_date&.strftime("%Y-%m-%dT%H:%M")
      ) %>
    </div>
    <div class="form-group col-md-12 mb-4">
      <%= render InputComponent.new(
         label: "Event Location",
         name: "event[location]",
         value: event.location,
         placeholder: "Search location..."
       ) %>
    </div>
    <div class="col-md-12 mb-4">
      <div class="flex flex-col md:flex-row gap-6">
        <div class="w-full md:w-1/2">
          <label class="block text-sm font-medium text-gray-700 mb-1"> Event Image </label>
          <%= render FileUploadComponent.new(form: f, field: :event_image) %>
        </div>
        <div class="w-full md:w-1/2">
          <label class="block text-sm font-medium text-gray-700 mb-1"> Current Preview </label>
          <% if event.event_image.attached? %>
            <div class="relative w-full h-48 rounded border border-gray-200 overflow-hidden group">
              <%= image_tag event.event_image, class: "w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="flex items-center justify-center w-full h-48 border-2 border-dashed border-gray-300 rounded bg-gray-50">
              <div class="text-center text-gray-400">
                <i class="fa fa-image text-2xl mb-2"></i>
                <p class="text-xs">No image set</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-md-12 mt-4 pt-4 border-t border-gray-100">
      <%= render ButtonComponent.new(intent: :primary, type: "submit", class: "w-full md:w-auto ml-auto") do %>
        <%= event.new_record? ? "Create Event" : "Update Event" %>
      <% end %>
    </div>
  </div>
<% end %>
