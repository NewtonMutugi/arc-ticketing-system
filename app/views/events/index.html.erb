<div class="flex justify-between">
  <div class="flex flex-col">
    <h1 class="font-bold text-2xl">Events</h1>
    <h2 class="text-l">All Events</h2>
  </div>
  <div class="block">
    <%= render ButtonComponent.new(type: "button", href: new_event_path) do %>
      <i class="fa-solid fa-plus"></i>
      Create Event
    <% end %>
  </div>
</div>
<hr class="my-4 border-gray-200"/>
<div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-8 mt-2">
  <% if @events %>
    <p>No events found</p>
  <% else %>
    <% @events.each do |event| %>
      <%= render CardComponent.new(class: "bg-white") do %>
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium text-gray-500 "><%= event.name %></h2>
          <i class="fa-solid fa-calendar text-gray-500"></i>
        </div>
        <p class="text-lg font-medium  my-6"><%= event.date %></p>
      <% end %>
    <% end %>
  <% end %>
</div>
