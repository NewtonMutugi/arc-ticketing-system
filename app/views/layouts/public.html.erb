<!DOCTYPE html>
<html>
  <head>
    <title>RubyConf Africa Tickets</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://kit.fontawesome.com/YOUR_KIT.js" crossorigin="anonymous"></script>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <nav class="bg-white border-b border-gray-200 py-4">
      <div class="max-w-5xl mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold tracking-tight">
          <span class="text-red-600">RubyConf</span> Tickets
        </a>
        <%= link_to "Organizer Login", new_dashboard_session_path, class: "text-sm text-gray-500 hover:text-red-600" %>
      </div>
    </nav>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
