<!DOCTYPE html>
<html>
  <head>
    <%= render "layouts/head" %>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <nav class="bg-white border-b border-gray-200 py-4">
      <div class="max-w-5xl mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold tracking-tight">
          <%= image_tag("/arc_logo.png", alt: "Africa Ruby Community Logo", class: "h-10 w-auto") %>
        </a>
        <% if Current.user %>
          <%= link_to admin_events_path, class: "flex items-center gap-3 hover:bg-gray-50 px-3 py-1.5 rounded-full transition-colors group" do %>
            <div class="text-right hidden sm:block">
              <p class="text-xs text-gray-500 group-hover:text-red-600">Signed in as</p>
              <p class="text-sm font-bold text-gray-900"><%= Current.user.first_name %></p>
            </div>
            <% if Current.user.avatar.attached? %>
              <%= image_tag Current.user.avatar, class: "w-9 h-9 rounded-full object-cover border border-gray-200" %>
            <% else %>
              <div class="w-9 h-9 rounded-full bg-red-100 flex items-center justify-center text-red-600 font-bold border border-red-200">
                <%= Current.user.first_name[0].upcase %>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to "Organizer Login", new_admin_session_path, class: "text-sm font-medium text-gray-500 hover:text-red-600 transition-colors" %>
        <% end %>
      </div>
    </nav>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
    <%= render "layouts/footer" %>
  </body>
</html>
