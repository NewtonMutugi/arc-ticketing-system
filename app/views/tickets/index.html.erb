<%= turbo_frame_tag "modal" %>
<div class="flex justify-between">
  <div class="flex flex-col">
    <h1 class="font-bold text-2xl">Tickets</h1>
    <h2 class="text-l">All Tickets</h2>
  </div>
  <div class="block">
    <%= render ButtonComponent.new(type: "button", href: new_event_ticket_path, data: { turbo_frame: "modal" }) do %>
      <i class="fa-solid fa-plus"></i>
      Create Ticket
    <% end %>
  </div>
</div>
<hr class="my-4 border-gray-200"/>
<div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-8 mt-2">
  <% if !@tickets %>
    <p>No tickets found</p>
  <% else %>
    <% if @tickets.empty? %>
      <div class="col-span-full text-center py-12 bg-gray-50 rounded-lg border border-dashed border-gray-300">
        <p class="text-gray-500">No Ticket found. Create one to get started!</p>
      </div>
    <% else %>
      <% @tickets.each do |ticket| %>
        <%= render CardComponent.new(class: "bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden flex flex-col") do %>
          <div class="bg-red-600 px-4 py-3 text-white flex justify-between items-center relative overflow-hidden">
            <div class="absolute -right-2 -top-2 opacity-10 transform rotate-12">
              <i class="fa-solid fa-ticket text-6xl"></i>
            </div>
            <h2 class="text-lg font-bold truncate z-10 mr-2"><%= ticket.title %></h2>
            <span class="bg-white/20 px-2 py-1 rounded text-sm font-semibold whitespace-nowrap z-10">
              <%= number_to_currency(ticket.price, unit: "Ksh ", precision: 0) %>
            </span>
          </div>
          <div class="flex flex-col sm:flex-row border-b border-gray-100 grow">
            <div class="w-full sm:w-1/3 bg-gray-100 relative min-h-[140px]">
              <% if ticket.ticket_image.attached? %>
                <%= image_tag ticket.ticket_image, class: "absolute inset-0 w-full h-full object-cover" %>
              <% else %>
                <div class="flex items-center justify-center h-full text-gray-400 bg-gray-50">
                  <i class="fa-solid fa-ticket text-4xl opacity-50"></i>
                </div>
              <% end %>
            </div>
            <div class="w-full sm:w-2/3 p-4 flex flex-col justify-center">
              <div class="grid grid-cols-3 gap-2 text-center mb-4 border-b border-gray-100 pb-3">
                <div>
                  <span class="block text-xl font-bold text-gray-800">0</span>
                  <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Sold</span>
                </div>
                <div class="border-l border-gray-100">
                  <span class="block text-xl font-bold text-gray-800"><%= ticket.quantity %></span>
                  <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Left</span>
                </div>
                <div class="border-l border-gray-100">
                  <span class="block text-xl font-bold text-gray-800">0</span>
                  <span class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Revenue</span>
                </div>
              </div>
              <div class="space-y-1 text-xs text-gray-600">
                <div class="flex justify-between">
                  <span class="font-semibold text-gray-700">Open:</span>
                  <span><%= ticket.start_sale_date&.strftime("%b %d, %Y") || "N/A" %></span>
                </div>
                <div class="flex justify-between">
                  <span class="font-semibold text-gray-700">Closes:</span>
                  <span><%= ticket.end_sale_date&.strftime("%b %d, %Y") || "N/A" %></span>
                </div>
                <div class="flex justify-between">
                  <span class="font-semibold text-gray-700">Group Size:</span>
                  <span><%= ticket.group_ticket_count || 1 %></span>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-auto bg-gray-50 px-4 py-2 flex justify-between items-center text-xs border-t border-gray-100">
            <span class="flex items-center text-green-600 font-bold bg-green-50 px-2 py-1 rounded-full border border-green-100">
              <span class="w-2 h-2 rounded-full bg-green-500 mr-2"></span>
              On Sale
            </span>
            <div class="flex gap-4 font-medium text-gray-500">
              <%= link_to edit_event_ticket_path(@event, ticket), class: "flex items-center hover:text-red-600 transition-colors", data: { turbo_frame: "modal" } do %>
                <i class="fa-solid fa-pen-to-square mr-1"></i> Edit
              <% end %>
              <div class="w-px h-4 bg-gray-300 self-center"></div>
              <%= link_to event_ticket_path(@event, ticket), class: "flex items-center hover:text-red-600 transition-colors" do %>
                <i class="fa-solid fa-eye mr-1"></i> View
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
</div>
