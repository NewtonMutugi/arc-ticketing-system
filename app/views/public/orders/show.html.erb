<% content_for :title, "Ticket Confirmed" %>
<div class="max-w-2xl mx-auto text-center py-12">
  <% if @order.paid? %>
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="fa-solid fa-check text-4xl text-green-600"></i>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Ticket Confirmed!</h1>
    <p class="text-gray-500 mb-8">See you at the event!</p>
  <% elsif @order.payment_reference.present? %>
    <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="fa-solid fa-hourglass-half text-4xl text-yellow-600"></i>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Payment Under Review</h1>
    <p class="text-gray-500 mb-4">We have received your reference: <span class="font-mono font-bold"><%= @order.payment_reference %></span></p>
    <div class="bg-yellow-50 text-yellow-800 p-4 rounded-lg text-sm max-w-md mx-auto mb-8">
      Your ticket will be emailed to you as soon as an admin verifies this transaction.
    </div>
  <% else %>
    <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="fa-solid fa-exclamation text-4xl text-red-600"></i>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Payment Required</h1>
    <%= link_to "Complete Payment", event_order_checkout_path(@event, @order), class: "inline-block mt-4 text-red-600 font-bold hover:underline" %>
  <% end %>
</div>
