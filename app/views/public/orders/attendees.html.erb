<% content_for :title, "Attendees" %>
<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div class="flex flex-col">
      <span class="text-sm font-bold text-red-600 uppercase tracking-wider">Step 2 of 3</span>
      <h1 class="text-3xl font-bold text-gray-900">Attendee Details</h1>
    </div>
    <div class="text-right">
      <div class="text-sm text-gray-500">Order Total</div>
      <div class="text-2xl font-bold text-gray-900"><%= number_to_currency(@order.total_cost, unit: "Ksh ", precision: 0) %></div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center flex-wrap gap-4">
      <div>
        <h2 class="text-lg font-medium text-gray-900">Who is attending?</h2>
        <p class="text-sm text-gray-500">Please provide details for each ticket holder.</p>
      </div>
      <% if @order.buyer_name.present? || @order.buyer_email.present? %>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="use_buyer_info" class="w-4 h-4 rounded border-gray-300 text-red-600 focus:ring-red-500 cursor-pointer">
          <label for="use_buyer_info" class="text-sm text-gray-700 cursor-pointer font-medium">I am one of the attendees</label>
        </div>
      <% end %>
    </div>
    <%= form_with url: event_order_confirm_path(@event, @order), method: :patch, local: true, class: "p-6 space-y-8" do |f| %>
      <%# Fetch existing attendees into an array to pull from %>
      <% existing_attendees = @order.attendees.to_a %>
      <% counter = 0 %>
      <% @order.order_items.each do |item| %>
        <% item.quantity.times do |i| %>
          <% attendee = existing_attendees[counter] %>
          <% counter += 1 %>
          <div class="p-4 rounded-lg border border-gray-200 hover:border-red-100 transition-colors relative group">
            <div class="absolute -top-3 left-4 bg-white px-2 text-sm font-bold text-gray-500 group-hover:text-red-600 transition-colors">
              Attendee #<%= counter %> - <span class="text-gray-400 font-normal"><%= item.ticket.title %></span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
              <input type="hidden" name="attendees[][ticket_id]" value="<%= item.ticket.id %>">
              <div>
                <%= render InputComponent.new(
                  label: "First Name",
                  name: "attendees[][first_name]",
                  id: "attendees_#{counter}_first_name",
                  value: attendee&.first_name,
                  type: "text",
                  placeholder: "",
                  required: true,
                ) %>
              </div>
              <div>
                <%= render InputComponent.new(
                  label: "Last Name",
                  name: "attendees[][last_name]",
                  id: "attendees_#{counter}_last_name",
                  type: "text",
                  placeholder: "",
                  value: attendee&.last_name,
                  required: true,
                ) %>
              </div>
              <div class="md:col-span-2">
                <%= render InputComponent.new(
                  label: "Email Address",
                  name: "attendees[][email]",
                  id: "attendees_#{counter}_email",
                  type: "email",
                  placeholder: "",
                  required: true,
                  value: attendee&.email,
                ) %>
                <p class="text-xs text-gray-500 mt-1">We'll send the ticket to this email.</p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      <div class="pt-4 border-t border-gray-100 flex justify-end gap-4">
        <% primary_ticket_id = @order.order_items.first&.ticket_id %>
        <% back_link = primary_ticket_id ? new_event_order_path(@event, ticket_id: primary_ticket_id, order_no: @order.order_no) : event_path(@event) %>
        <%= link_to back_link, class: "text-gray-600 hover:text-gray-900 flex items-center gap-2 font-medium" do %>
          <i class="fa-solid fa-arrow-left"></i>
          Edit Buyer information
        <% end %>
        <%= f.submit "Continue to Payment", class: "bg-red-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-red-700 transition shadow-lg cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const useBuyerInfoCheckbox = document.getElementById('use_buyer_info');
    if (!useBuyerInfoCheckbox) return;

    const buyerFirstName = "<%= j @order.buyer_name.to_s.split.first %>";
    const buyerLastName = "<%= j @order.buyer_name.to_s.split[1..-1]&.join(' ') %>";
    const buyerEmail = "<%= j @order.buyer_email %>";

    const firstAttendeeFirstName = document.getElementById('attendees_1_first_name');
    const firstAttendeeLastName = document.getElementById('attendees_1_last_name');
    const firstAttendeeEmail = document.getElementById('attendees_1_email');

    useBuyerInfoCheckbox.addEventListener('change', function(e) {
      if (this.checked) {
        if (firstAttendeeFirstName && !firstAttendeeFirstName.value) firstAttendeeFirstName.value = buyerFirstName;
        if (firstAttendeeLastName && !firstAttendeeLastName.value) firstAttendeeLastName.value = buyerLastName;
        if (firstAttendeeEmail && !firstAttendeeEmail.value) firstAttendeeEmail.value = buyerEmail;
      } else {
        if (firstAttendeeFirstName && firstAttendeeFirstName.value === buyerFirstName) firstAttendeeFirstName.value = '';
        if (firstAttendeeLastName && firstAttendeeLastName.value === buyerLastName) firstAttendeeLastName.value = '';
        if (firstAttendeeEmail && firstAttendeeEmail.value === buyerEmail) firstAttendeeEmail.value = '';
      }
    });

    if (firstAttendeeFirstName && firstAttendeeFirstName.value === buyerFirstName &&
        firstAttendeeLastName && firstAttendeeLastName.value === buyerLastName &&
        firstAttendeeEmail && firstAttendeeEmail.value === buyerEmail && buyerEmail !== "") {
      useBuyerInfoCheckbox.checked = true;
    }
  });
</script>
