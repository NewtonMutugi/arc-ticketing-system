<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div class="flex flex-col">
      <span class="text-sm font-bold text-red-600 uppercase tracking-wider">Step 2 of 3</span>
      <h1 class="text-3xl font-bold text-gray-900">Attendee Details</h1>
    </div>
    <div class="text-right">
      <div class="text-sm text-gray-500">Order Total</div>
      <div class="text-2xl font-bold text-gray-900"><%= number_to_currency(@order.total_cost, unit: "Ksh ", precision: 0) %></div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Who is attending?</h2>
      <p class="text-sm text-gray-500">Please provide details for each ticket holder.</p>
    </div>
    <%= form_with url: event_order_confirm_path(@event, @order), method: :patch, local: true, class: "p-6 space-y-8" do |f| %>
      <% counter = 0 %>
      <% @order.order_items.each do |item| %>
        <% item.quantity.times do |i| %>
          <% counter += 1 %>
          <div class="p-4 rounded-lg border border-gray-200 hover:border-red-100 transition-colors relative group">
            <div class="absolute -top-3 left-4 bg-white px-2 text-sm font-bold text-gray-500 group-hover:text-red-600 transition-colors">
              Attendee #<%= counter %> - <span class="text-gray-400 font-normal"><%= item.ticket.title %></span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
              <input type="hidden" name="attendees[][ticket_id]" value="<%= item.ticket.id %>">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                <input type="text" name="attendees[][first_name]" required class="w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                <input type="text" name="attendees[][last_name]" required class="w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm">
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <input type="email" name="attendees[][email]" required class="w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm">
                <p class="text-xs text-gray-500 mt-1">We'll send the ticket to this email.</p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      <div class="pt-4 border-t border-gray-100 flex justify-end gap-4">
        <%= f.submit "Continue to Payment", class: "bg-red-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-red-700 transition shadow-lg cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
