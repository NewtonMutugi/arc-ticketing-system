<% content_for :title, "Checkout" %>
<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div class="flex flex-col">
      <span class="text-sm font-bold text-red-600 uppercase tracking-wider">Step 3 of 3</span>
      <h1 class="text-3xl font-bold text-gray-900">Payment Verification</h1>
    </div>
    <div class="text-right">
      <div class="text-sm text-gray-500">Amount Due</div>
      <div class="text-2xl font-bold text-gray-900"><%= number_to_currency(@order.total_cost, unit: "Ksh ", precision: 0) %></div>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-1 space-y-4">
      <h3 class="font-bold text-gray-700">Select Method</h3>
      <label class="block cursor-pointer group">
        <input type="radio" name="payment_tab" value="mpesa" checked class="peer sr-only" onchange="togglePayment('mpesa')">
        <div class="p-4 rounded-xl border border-gray-200 peer-checked:border-green-500 peer-checked:bg-green-50 peer-checked:text-green-700 hover:border-gray-300 transition">
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 rounded-full border border-gray-400 peer-checked:border-green-600 peer-checked:bg-green-600"></div>
            <div class="font-bold">M-PESA</div>
          </div>
          <div class="text-xs text-gray-500 mt-1 ml-6">Automatic STK Push</div>
        </div>
      </label>
      <label class="block cursor-pointer group">
        <input type="radio" name="payment_tab" value="paypal" class="peer sr-only" onchange="togglePayment('paypal')">
        <div class="p-4 rounded-xl border border-gray-200 peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:text-blue-700 hover:border-gray-300 transition">
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 rounded-full border border-gray-400 peer-checked:border-blue-600 peer-checked:bg-blue-600"></div>
            <div class="font-bold">PayPal / Card</div>
          </div>
          <div class="text-xs text-gray-500 mt-1 ml-6">International Cards</div>
        </div>
      </label>
    </div>
    <div class="md:col-span-2">
      <div class="mb-4">
        <%= link_to event_order_attendees_path(@event, @order), class: "text-sm text-gray-600 hover:text-red-600 flex items-center gap-1" do %>
          <i class="fa-solid fa-chevron-left text-xs"></i> Back to Attendee Details
        <% end %>
      </div>
      <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm min-h-[350px]">
        <div id="mpesa-section" class="payment-section">
          <% if Setting.mpesa_mode == 'automated' %>
            <%= form_with url: event_order_pay_path(@event, @order), method: :patch do |f| %>
              <%= hidden_field_tag :payment_method, "mpesa" %>
              <div class="text-center py-6">
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                  <i class="fa-solid fa-mobile-screen-button text-2xl"></i>
                </div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Pay with M-PESA</h4>
                <p class="text-sm text-gray-500 mb-6">Enter the M-Pesa number to pay.</p>
                <div class="max-w-xs mx-auto mb-8 relative">
                  <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Phone Number</label>
                  <%= telephone_field_tag :mpesa_phone_number, @order.buyer_phone_no, class: "w-full text-center text-2xl font-bold text-gray-900 border-b-2 border-gray-200 focus:border-green-600 border-t-0 border-x-0 bg-transparent focus:ring-0 placeholder-gray-300 transition-colors py-2", placeholder: "07XX XXX XXX", required: true %>
                </div>
                <%= f.submit "Pay #{number_to_currency(@order.total_cost, unit: 'Ksh ', precision: 0)}", class: "w-full max-w-sm bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition shadow-lg cursor-pointer text-lg", data: { turbo_submits_with: "Loading..." } %>
              </div>
            <% end %>
          <% else %>
            <%= form_with model: @order, url: event_order_pay_path(@event, @order), method: :patch do |f| %>
              <%= f.hidden_field :payment_provider, value: "Mpesa" %>
              <div class="text-center py-6">
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                  <i class="fa-solid fa-money-bill-transfer text-2xl"></i>
                </div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">Manual M-PESA Payment</h4>
                <div class="bg-gray-50 p-4 rounded-lg inline-block text-left mb-6 w-full max-w-sm">
                  <p class="text-sm text-gray-700 mb-2"><span class="font-bold">1.</span> Go to M-PESA &gt; Lipa na M-PESA &gt; Paybill</p>
                  <p class="text-sm text-gray-700 mb-2"><span class="font-bold">2.</span> Enter Business No: <span class="font-bold text-black border border-gray-300 px-2 py-1 rounded bg-white"><%= Setting.mpesa_business_number %></span></p>
                  <p class="text-sm text-gray-700 mb-2"><span class="font-bold">3.</span> Enter Account No: <span class="font-bold text-black border border-gray-300 px-2 py-1 rounded bg-white">
                      <%# <%= @order.order_no %>
                      [Your Name]
                    </span></p>
                  <p class="text-sm text-gray-700"><span class="font-bold">4.</span> Amount: <span class="font-bold text-black border border-gray-300 px-2 py-1 rounded bg-white"><%= number_to_currency(@order.total_cost, unit: "Ksh ", precision: 0) %></span></p>
                </div>
                <div class="max-w-xs mx-auto mb-8 relative">
                  <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">M-PESA Confirmation Code</label>
                  <%= f.text_field :payment_reference, required: true, class: "w-full text-center text-xl font-bold text-gray-900 border-b-2 border-gray-200 focus:border-green-600 border-t-0 border-x-0 bg-transparent focus:ring-0 placeholder-gray-300 transition-colors py-2 uppercase", placeholder: "e.g. QLK2...", autocomplete: "off" %>
                </div>
                <%= f.submit "Verify Payment", class: "w-full max-w-sm bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition shadow-lg cursor-pointer text-lg", data: { turbo_submits_with: "Loading..." } %>
              </div>
            <% end %>
          <% end %>
        </div>
        <div id="paypal-section" class="payment-section hidden">
          <div class="text-center py-6">
            <h4 class="text-xl font-bold text-gray-900 mb-6">Pay via PayPal or Card</h4>
            <div id="paypal-button-container" class="w-full max-w-sm mx-auto min-h-[150px]"></div>
            <p class="text-xs text-gray-400 mt-4">
              Total: <strong>$<%= (@order.total_cost / 130.0).round(2) %></strong> (Approx)
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  window.isPayPalInitialized = window.isPayPalInitialized || false;

  // Make the function available globally so the inline HTML onchange="" can find it
  window.togglePayment = function(method) {
    document.querySelectorAll('.payment-section').forEach(el => el.classList.add('hidden'));
    document.getElementById(method + '-section').classList.remove('hidden');

    if (method === 'paypal' && !window.isPayPalInitialized) {
      loadPayPalSDK();
    }
  };

  function loadPayPalSDK() {
    if (window.paypal) {
      renderPayPalButtons();
    } else {
      const script = document.createElement('script');
      const clientId = "<%= ENV['PROD_PAYPAL_CLIENT_ID'] %>";
      // console.log(`PROD_PAYPAL_CLIENT_ID=${clientId}`);

      script.src = "https://www.paypal.com/sdk/js?client-id=<%= ENV['PROD_PAYPAL_CLIENT_ID'] %>&currency=USD";
      script.onload = renderPayPalButtons;
      document.head.appendChild(script);
    }
  }

  function renderPayPalButtons() {
    if (window.isPayPalInitialized) return;

    // Safety check: Does the container actually exist on this page right now?
    const container = document.getElementById('paypal-button-container');
    if (!container) return;

    paypal.Buttons({
      style: { layout: 'vertical', color: 'blue', shape: 'rect', label: 'pay' },

      // STEP 1: CREATE ORDER
      createOrder: function(data, actions) {
        return fetch('/paypal/create_order', {
          method: 'post',
          headers: {
            'content-type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ order_no: "<%= @order.order_no %>" })
        })
        .then(async (res) => {
          const json = await res.json();

          if (!res.ok || json.error) {
            console.error("Server Error:", json);
            alert("Could not initiate payment: " + (json.error || "Unknown error"));
            throw new Error("Server Error");
          }

          return json.id;
        });
      },

      // STEP 2: CAPTURE ORDER
      onApprove: function(data, actions) {
        return fetch('/paypal/capture_order', {
          method: 'post',
          headers: {
            'content-type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ orderID: data.orderID, order_no: "<%= @order.order_no %>" })
        })
        .then(async (res) => {
          const json = await res.json();

          if (!res.ok || json.error) {
            console.error("Capture Error:", json);
            alert("Payment failed: " + (json.error || "Please try again."));
          } else if (json.status === 'COMPLETED') {
            window.location.href = "<%= event_order_path(@event, @order) %>";
          }
        });
      },

      onError: function(err) {
        console.error("PayPal SDK Error:", err);
        alert("An error occurred with PayPal. Please try again.");
      }
    }).render('#paypal-button-container');

    window.isPayPalInitialized = true;
  }

  // Ensure state resets if the user leaves the checkout page and comes back
  document.addEventListener("turbo:before-cache", function() {
    window.isPayPalInitialized = false;
  }, { once: true });
</script>
