<div class="relative bg-gray-900 rounded-3xl overflow-hidden mb-12 group">
  <% if defined?(Current) && Current.user %>
    <div class="absolute top-6 right-6 z-30">
      <%= link_to dashboard_events_path, class: "flex items-center gap-3 bg-black/30 backdrop-blur-md border border-white/10 pl-2 pr-4 py-2 rounded-full hover:bg-black/50 hover:border-red-500/50 transition-all duration-300 group/badge shadow-lg" do %>
        <div class="relative">
          <% if Current.user.respond_to?(:avatar) && Current.user.avatar&.attached? %>
            <%= image_tag Current.user.avatar, class: "w-9 h-9 rounded-full object-cover border-2 border-white/20 group-hover/badge:border-red-500 transition-colors" %>
          <% else %>
            <div class="w-9 h-9 rounded-full bg-indigo-600 flex items-center justify-center text-white text-xs font-bold border-2 border-white/20 group-hover/badge:border-red-500 transition-colors shadow-inner">
              <%= Current.user.first_name.to_s[0]&.upcase || "U" %>
            </div>
          <% end %>
          <span class="absolute bottom-0 right-0 block h-2.5 w-2.5 rounded-full ring-2 ring-gray-900 bg-green-400"></span>
        </div>
        <div class="text-left hidden sm:block">
          <p class="text-[10px] uppercase tracking-wider text-gray-400 font-bold group-hover/badge:text-red-400 transition-colors">Go to Dashboard</p>
          <p class="text-sm font-bold text-white leading-none"><%= Current.user.first_name %></p>
        </div>
        <i class="fa-solid fa-arrow-right-long text-white/40 ml-1 group-hover/badge:text-white group-hover/badge:translate-x-1 transition-all"></i>
      <% end %>
    </div>
  <% end %>
  <div class="absolute inset-0 opacity-40">
    <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out" alt="Conference crowd">
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/80 to-transparent"></div>
  <div class="relative z-10 px-8 py-16 md:py-24 max-w-2xl">
    <span class="inline-block py-1 px-3 rounded-full bg-red-600/20 text-red-400 text-xs font-bold tracking-wider mb-4 border border-red-600/30">
      PREMIUM EVENTS
    </span>
    <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6">
      Discover the best <br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-orange-500">Tech Conferences</span>
    </h1>
    <p class="text-lg text-gray-300 mb-8 leading-relaxed">
      Secure your spot at the biggest developer gatherings in Africa. No sign-up required—just choose your event and grab your ticket.
    </p>
    <div class="bg-white/10 backdrop-blur-md p-2 rounded-lg border border-white/20 flex max-w-md focus-within:bg-white/20 transition-colors">
      <input type="text" placeholder="Search events..." class="bg-transparent border-none text-white placeholder-gray-400 focus:ring-0 w-full text-sm">
      <button class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-md font-bold text-sm transition shadow-lg hover:shadow-red-900/50">
        Search
      </button>
    </div>
  </div>
</div>
<div class="mb-12">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold text-gray-900">Upcoming Events</h2>
    <span class="text-sm text-gray-500 font-medium"><%= @events.count %> events found</span>
  </div>
  <% if @events.empty? %>
    <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-gray-300">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
        <i class="fa-regular fa-calendar-xmark text-2xl text-gray-400"></i>
      </div>
      <h3 class="text-lg font-medium text-gray-900">No events found</h3>
      <p class="text-gray-500">Check back later for new announcements.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @events.each do |event| %>
        <%= link_to event_path(event), class: "group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col overflow-hidden h-full" do %>
          <div class="relative h-56 overflow-hidden bg-gray-200">
            <% if event.event_image.attached? %>
              <%= image_tag event.event_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-gray-400">
                <i class="fa-regular fa-image text-4xl"></i>
              </div>
            <% end %>
            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur rounded-lg p-2 text-center shadow-lg min-w-[60px]">
              <span class="block text-xs font-bold text-red-600 uppercase tracking-wider">
                <%= event.start_date.strftime("%b") %>
              </span>
              <span class="block text-xl font-extrabold text-gray-900 leading-none">
                <%= event.start_date.strftime("%d") %>
              </span>
            </div>
            <div class="absolute bottom-4 left-4">
              <span class="bg-gray-900/80 backdrop-blur text-white text-[10px] font-bold px-2 py-1 rounded">
                CONFERENCE
              </span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-red-600 transition-colors line-clamp-2">
              <%= event.title %>
            </h3>
            <div class="flex items-start text-sm text-gray-500 mb-4">
              <i class="fa-solid fa-location-dot mt-1 mr-2 text-gray-400"></i>
              <span class="line-clamp-1"><%= event.location %></span>
            </div>
            <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400 font-medium uppercase">Tickets from</p>
                <% min_price = event.tickets.minimum(:price) %>
                <p class="text-lg font-bold text-gray-900">
                  <%= min_price.to_f > 0 ? number_to_currency(min_price, unit: "Ksh ", precision: 0) : "Free" %>
                </p>
              </div>
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-50 text-red-600 group-hover:bg-red-600 group-hover:text-white transition-colors">
                <i class="fa-solid fa-arrow-right"></i>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
<div class="bg-gray-50 rounded-2xl p-8 md:p-12 text-center border border-gray-200">
  <h2 class="text-2xl font-bold text-gray-900 mb-4">Don't miss the next big event</h2>
  <p class="text-gray-600 mb-6 max-w-lg mx-auto">Subscribe to our newsletter to get early bird alerts and developer community news.</p>
  <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
    <input type="email" placeholder="Enter your email" class="flex-1 rounded-lg border-gray-300 focus:ring-red-500 focus:border-red-500">
    <button class="bg-gray-900 text-white px-6 py-2.5 rounded-lg font-bold hover:bg-black transition">
      Subscribe
    </button>
  </form>
</div>
