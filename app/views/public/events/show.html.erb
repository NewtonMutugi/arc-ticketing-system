<% content_for :title, "#{@event.title}" %>
<div class="max-w-4xl mx-auto">
  <% if @event.event_image.attached? %>
    <%= image_tag @event.event_image, class: "w-full h-64 md:h-96 object-cover rounded-xl mb-8 shadow-sm" %>
  <% end %>
  <div class="text-center mb-10">
    <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4"><%= @event.title %></h1>
    <div class="flex flex-wrap justify-center gap-6 text-gray-600">
      <div class="flex items-center bg-gray-50 px-4 py-2 rounded-full border border-gray-100">
        <i class="fa-regular fa-calendar mr-2 text-red-600"></i>
        <%= @event.start_date.to_fs(:long) %>
      </div>
      <div class="flex items-center bg-gray-50 px-4 py-2 rounded-full border border-gray-100">
        <i class="fa-solid fa-location-dot mr-2 text-red-600"></i>
        <%= @event.location %>
      </div>
    </div>
  </div>
  <div class="prose max-w-none text-gray-600 mb-12">
    <%= simple_format @event.description %>
  </div>
  <div class="border-t border-gray-200 pt-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Available Tickets</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @event.tickets.where(status: true).each do |ticket| %>
        <%= link_to new_event_order_path(@event, ticket_id: ticket.id), class: "block h-full group" do %>
          <div class="border border-gray-200 rounded-xl p-6 hover:border-red-200 hover:shadow-md transition-all duration-200 flex flex-col justify-between h-full">
            <div>
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-600 transition-colors"><%= ticket.title %></h3>
                <span class="bg-red-50 text-red-700 font-bold px-3 py-1 rounded-full text-sm">
                  <%= ticket.price == 0 ? "Free" : number_to_currency(ticket.price, unit: "Ksh ", precision: 0) %>
                </span>
              </div>
              <p class="text-gray-500 text-sm mb-6"><%= ticket.description %></p>
            </div>
            <% if ticket.sold_out? %>
              <div class="w-full bg-gray-100 text-gray-400 font-bold py-3 rounded-lg text-center cursor-not-allowed">
                Sold Out
              </div>
            <% else %>
              <%#
              <div class="w-full bg-gray-900 text-white text-center font-bold py-3 rounded-lg group-hover:bg-red-600 transition-colors">
                Select Ticket <i class="fa-solid fa-arrow-right ml-2"></i>
              </div>
              %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
