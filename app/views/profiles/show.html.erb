<div class="max-w-screen-xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-8">
    <div class="rounded-lg bg-gray-200 lg:col-span-1">
      <%= render CardComponent.new(class: "h-full bg-white") do %>
        <div class="flex flex-col items-center">
          <% if Current.user.avatar.attached? %>
            <%= image_tag Current.user.avatar, class: "size-24 rounded-full object-cover mb-4" %>
          <% else %>
             <img
              src="https://ui-avatars.com/api/?name=<%= Current.user.first_name %>&background=random"
              alt="<%= Current.user.full_name %>"
              class="size-24 rounded-full object-cover mb-4"
            />
          <% end %>

          <h3 class="text-xl font-bold text-gray-900"><%= Current.user.full_name %></h3>
          <p class="text-sm text-gray-500"><%= Current.user.email_address %></p>
        </div>
      <% end %>
    </div>
    <div class="rounded-lg bg-gray-200 lg:col-span-2">
      <%= render CardComponent.new(class: "bg-white") do %>
        <h2 class="text-lg font-medium text-gray-900 mb-6">Edit Profile</h2>

        <%= form_with model: Current.user, url: profile_path, class: "space-y-4" do |form| %>
          <% if form.object.errors.any? %>
            <div role="alert" class="rounded border-s-4 border-red-500 bg-red-50 p-4 mb-4">
              <strong class="block font-medium text-red-800"> Something went wrong </strong>
              <p class="mt-2 text-sm text-red-700">
                <%= form.object.errors.full_messages.first %>
              </p>
            </div>
          <% end %>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <%= render InputComponent.new(
                name: "user[first_name]",
                label: "First Name",
                value: form.object.first_name,
                required: true
              )%>
            </div>

            <div>
               <%= render InputComponent.new(
                name: "user[last_name]",
                label: "Last Name",
                value: form.object.last_name,
                required: true
              )%>
            </div>
          </div>

          <div>
             <label class="block text-sm font-medium text-gray-700 mb-1"> Avatar </label>
             <%= render FileUploadComponent.new(form: form, field: :avatar) %>
          </div>

          <div class="mt-4 flex justify-end">
            <%= render ButtonComponent.new(type: "submit") do %>
              Update Profile
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
